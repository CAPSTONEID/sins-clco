+fn percent_bar(percent: i64) -> String {
+    let percent = percent.clamp(0, 100);
+    let filled = ((percent + 5) / 10) as usize;
+    let empty = 10usize.saturating_sub(filled);
+    format!("{}{} {percent}%", "█".repeat(filled), "░".repeat(empty))
+}
+
+fn korean_limit_duration(minutes: i64) -> String {
+    if minutes >= 1440 && minutes % 1440 == 0 {
+        format!("{}일 사용량", minutes / 1440)
+    } else if minutes >= 60 && minutes % 60 == 0 {
+        format!("{}시간 사용량", minutes / 60)
+    } else {
+        format!("{minutes}분 사용량")
+    }
+}
+
+fn status_line_spans(top_parts: &[String], bottom_parts: &[String]) -> Vec<Span<'static>> {
+    let mut spans = Vec::new();
+    push_status_parts(&mut spans, top_parts);
+    if !bottom_parts.is_empty() {
+        spans.push(Span::raw("\u{E000}"));
+        push_status_parts(&mut spans, bottom_parts);
+    }
+    spans
+}
+
+fn push_status_parts(spans: &mut Vec<Span<'static>>, parts: &[String]) {
+    for (index, part) in parts.iter().enumerate() {
+        if index > 0 {
+            spans.push(Span::styled("  │  ", Style::default().fg(Color::DarkGray)));
+        }
+        spans.push(Span::styled(part.clone(), status_item_style(part)));
+    }
+}
+
+fn usage_percent(part: &str) -> u8 {
+    part
+        .split_whitespace()
+        .find_map(|tok| tok.strip_suffix('%')?.parse::<u8>().ok())
+        .unwrap_or(0)
+}
+
+fn five_hour_limit_usage_color(part: &str) -> Color {
+    if usage_percent(part) >= 90 {
+        Color::Rgb(0xFF, 0x00, 0x3C)
+    } else {
+        Color::Rgb(0xFD, 0xFF, 0x00)
+    }
+}
+
+/// Returns a color based on how much of the rate-limit window has been consumed.
+/// The percentage is parsed from the trailing "NN% ..." portion of the part string.
+fn limit_usage_color(part: &str) -> Color {
+    let used_pct = usage_percent(part);
+    match used_pct {
+        0..=49 => Color::Green,
+        50..=79 => Color::LightYellow,
+        80..=99 => Color::LightRed,
+        _ => Color::Red,
+    }
+}
+
+fn status_item_style(part: &str) -> Style {
+    let color = if part.starts_with("모델명") {
+        Color::Cyan
+    } else if part.starts_with("상태") {
+        Color::Yellow
+    } else if part.starts_with("남은맥락") {
+        Color::LightGreen
+    } else if part.starts_with("Context 사용량") {
+        Color::LightMagenta
+    } else if part.starts_with("5시간 사용량") {
+        five_hour_limit_usage_color(part)
+    } else if part.contains("시간 사용량")
+        || part.contains("분 사용량")
+        || part.contains("일 사용량")
+    {
+        limit_usage_color(part)
+    } else if part.starts_with("프로젝트명") {
+        Color::LightCyan
+    } else if part.starts_with("폴더") {
+        Color::LightBlue
+    } else if part.starts_with("🌿 브랜치") {
+        Color::LightGreen
+    } else {
+        Color::Gray
+    };
+    Style::default().fg(color)
+}
+
 fn parse_items_with_invalids<T>(ids: impl IntoIterator<Item = String>) -> (Vec<T>, Vec<String>)
 where
     T: std::str::FromStr,
