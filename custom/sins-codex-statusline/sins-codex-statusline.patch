+pub(crate) fn footer_line_display_width(line: &Line<'static>) -> usize {
+    split_footer_line(line.clone())
+        .iter()
+        .map(Line::width)
+        .max()
+        .unwrap_or(0)
+}
+
+pub(crate) fn footer_line_display_height(line: &Line<'static>) -> usize {
+    split_footer_line(line.clone()).len()
+}
+
+fn split_footer_line(line: Line<'static>) -> Vec<Line<'static>> {
+    let Line {
+        style,
+        alignment,
+        spans,
+    } = line;
+    let mut split_spans: Vec<Vec<Span<'static>>> = vec![Vec::new()];
+    for span in spans {
+        let span_style = span.style;
+        let mut segment = String::new();
+        for ch in span.content.chars() {
+            if ch == '\n' || ch == '\u{E000}' {
+                if !segment.is_empty() {
+                    split_spans
+                        .last_mut()
+                        .expect("split line has current row")
+                        .push(Span::styled(std::mem::take(&mut segment), span_style));
+                }
+                split_spans.push(Vec::new());
+            } else {
+                segment.push(ch);
+            }
+        }
+        if !segment.is_empty() {
+            split_spans
+                .last_mut()
+                .expect("split line has current row")
+                .push(Span::styled(segment, span_style));
+        }
+    }
+    if split_spans.is_empty() {
+        vec![Line::from(String::new())]
+    } else {
+        split_spans
+            .into_iter()
+            .map(|spans| Line {
+                style,
+                alignment,
+                spans,
+            })
+            .collect()
+    }
+}
